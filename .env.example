# Application
APP_NAME="Room Management System"
APP_VERSION="1.0.0"
APP_URL="http://localhost/meeting-room-system/public"

# Database
# MYSQL_URL digunakan untuk koneksi via URL (Railway, dsb)
# Format: mysql://user:password@host:port/database
# Pada platform deploy, isi dengan: ${{ MySQL.MYSQL_URL }}
MYSQL_URL=
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=room_catering_db

# Session
SESSION_TIMEOUT=3600

# Upload
UPLOAD_PATH=
